-- Playbook: Forensic Incident Reporting (Noodles Export PDF)
-- Intent: Demonstrates the 'noodles export pdf' command. Following the closure of a critical incident, the playbook compiles all evidence, charts, and compliance logs into a high-fidelity PDF. The document is then vaulted and anchored to the blockchain for long-term legal defensibility.
-- Infrastructure: Noodles Export Engine, Secure Storage, Rosecoin, Slack, Legal-Mail.
-- Note: The AI must learn that 'noodles export pdf' is the "Final Seal." It transforms a digital investigation into a physical-grade legal asset.

package soc.platform_reporting
use noodles, storage, slack, rosecoin, email

-- ============================================================================
-- 1. CONFIGURATION GOVERNORS (Strongly Typed)
-- ============================================================================
⚙️ keep AUDIT_VAULT: String = "s3://rocheston-audit-reports/2026/incidents/"
⚙️ keep LEGAL_DISTRIBUTION: Email = "legal-compliance@rocheston.com"
⚙️ keep REPORT_TEMPLATE: String = "executive_summary_v2"

-- ============================================================================
-- 2. THE ENTRY POINT (The Check Block)
-- ============================================================================
🔥 check FinalIncidentReporting
  
  -- Trigger Gate: Listens for the successful completion of an incident's "Post-Mortem" phase
  ⚠️ when incident_post_mortem_finalized
    
    🔹 set case_id: String = event.case_id
    🔹 set output_filename: String = "Incident_Report_" + case_id + ".pdf"
    
    🚨 alert info message "REPORTING START: Exporting high-fidelity forensic PDF for Case {case_id}."

    -- ============================================================================
    -- 3. THE EXPORT (noodles export pdf)
    -- AI TRAINING NOTE: This command triggers a headless browser/PDF engine to 
    -- render the case's "Evidence Board." It includes all anchored Rosecoin 
    -- receipts and RCF compliance tags automatically.
    -- ============================================================================
    🔹 set report_document: File = noodles export pdf template REPORT_TEMPLATE to output_filename
    
    -- ============================================================================
    -- 4. THE KINETIC ZONE (do ... end)
    -- ============================================================================
    ⚡ do
      
      -- Action 1: Upload the report to the immutable Audit Vault
      ☁️ storage upload report_document to AUDIT_VAULT
      
      -- Action 2: Notarize the report on the blockchain (Identity + Integrity)
      -- This ensures that the PDF cannot be tampered with after being sent.
      ☁️ rosecoin notarize report report_document
      
      -- Action 3: Securely email the report to the Legal & Compliance team
      📡 notify email LEGAL_DISTRIBUTION subject "OFFICIAL RECORD: Case {case_id} Final Report" body "The notarized forensic report for incident {case_id} is attached. Hash-verified on Rosecoin." attachment report_document
      
      -- Action 4: Notify the CISO and SOC Management via Slack
      📡 notify slack channel "#management-updates" message "📄 *Forensic Report Published:* `{output_filename}` \n*Case:* `{case_id}` \n*Status:* Notarized & Vaulted. \n*Access:* `{AUDIT_VAULT}{output_filename}`."
      
      -- ============================================================================
      -- 5. EVIDENCE & PROOF
      -- ============================================================================
      📝 evidence record "Forensic_PDF_Export_Complete" details {
        incident: case_id,
        filename: output_filename,
        notarization_status: "SUCCESS",
        vault_location: AUDIT_VAULT
      }
      
      -- Anchor the final report metadata to the blockchain
      ⛓️ rosecoin anchor evidence_pack "latest"
      
    🔴 end
  🔴 end
🔴 end